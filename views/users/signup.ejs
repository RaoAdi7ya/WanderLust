<% layout('layouts/boilerplate') %>

<div class="row min-vh-75 align-items-center justify-content-center mt-4">
  <div class="col-11 col-sm-8 col-md-5 col-lg-4">
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <div class="text-center mb-4">
        <i class="fa-regular fa-compass fa-2x" style="color: #fe424d;"></i>
        <h3 class="mt-2 fw-bold">Create account</h3>
        <p class="text-muted small">Join WanderLust today</p>
      </div>

      <form action="/signup" method="POST" class="needs-validation" novalidate>
        <div class="mb-3">
          <label for="username" class="form-label fw-semibold">Username</label>
          <input type="text" name="username" id="username" placeholder="Enter username" required class="form-control rounded-3" />
          <div class="valid-feedback">Looks good!</div>
        </div>

        <div class="mb-3">
          <label for="email" class="form-label fw-semibold">Email</label>
          <input type="email" name="email" id="email" placeholder="Enter email" required class="form-control rounded-3" />
        </div>

        <div class="mb-4">
          <label for="password" class="form-label fw-semibold">Password</label>
          <input type="password" name="password" id="password" placeholder="Enter password" required class="form-control rounded-3" />
        </div>

        <button class="btn w-100 rounded-3 fw-semibold" style="background-color: #fe424d; color: white;">Sign Up</button>
      </form>

      <p class="text-center text-muted small mt-3">
        Already have an account? <a href="/login" style="color: #fe424d;">Log In</a>
      </p>
    </div>
  </div>
</div>