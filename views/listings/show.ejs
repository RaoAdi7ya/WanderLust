<% layout('layouts/boilerplate') %>

<div class="row mt-3">
  <!-- Listing Title -->
  <div class="col-8 offset-3">
    <h3><%= listing.title %></h3>
  </div>

  <!-- Listing Card -->
  <div class="card col-6 offset-3 show-card listing-card">
    <img
      src="<%= listing.image.url %>"
      class="card-img-top show-img"
      alt="Listing_image"
    />

    <div class="card-body">
      <!-- Owner Info -->
      <p class="card-text">
        <% if(listing.owner) { %>
          <b>Owner:</b> <i><%= listing.owner.username %></i><br />
        <% } %>
      </p>

      <!-- Description -->
      <p class="card-text">
        <%= listing.description %>
      </p>

      <!-- Price -->
      <p class="card-text">
        <b>Price:</b> &#8377;<%= listing.price.toLocaleString("en-IN") %>
      </p>

      <!-- Location -->
      <p class="card-text">
        <b>Location:</b> <%= listing.location %>
      </p>

      <!-- Country -->
      <p class="card-text">
        <b>Country:</b> <%= listing.country %>
      </p>
    </div>
  </div>

  <br />

  <!-- Contact Owner Section (only show if not owner) -->
  <% if(!currentUser || (currentUser && currentUser._id.toString() !== listing.owner._id.toString())) { %>
    <div class="col-8 offset-3 mb-3">
      <hr />
      <h4>Contact Owner</h4>
      <p><b>Email:</b> <%= listing.owner.email %></p>
    </div>
  <% } %>

  <!-- Edit/Delete Buttons (only show if owner) -->
  <% if(currentUser && currentUser._id.toString() === listing.owner._id.toString()) { %>
    <div class="btns">
      <a
        href="/listings/<%= listing._id %>/edit"
        class="btn btn-dark col-1 offset-3 edit-btn"
      >
        Edit
      </a>

      <form
        action="/listings/<%= listing._id %>?_method=DELETE"
        method="POST"
        style="display: inline"
      >
        <button type="submit" class="btn btn-dark offset-5">
          Delete
        </button>
      </form>
    </div>
  <% } %>

  <!-- Reviews Section -->
  <div class="col-8 offset-3 mb-3">
    <hr />

    <!-- Leave a Review Form (only show if logged in) -->
    <% if(currentUser) { %>
      <h4>Leave a Review</h4>

      <form
        action="/listings/<%= listing._id %>/reviews"
        method="POST"
        class="needs-validation"
        novalidate
      >
        <!-- Range Input -->
        <!-- <div class="mb-3 mt-3">
          <label for="rating" class="form-label">Rating:</label>
          <input
            type="range"
            min="1"
            max="5"
            id="rating"
            name="review[rating]"
            class="form-range"
          />
        </div> -->

        <!-- Star Rating -->
        <div class="mb-3 mt-3">
          <label for="rating" class="form-label">Rating:</label>

          <fieldset class="starability-slot">

            <input
              type="radio"
              id="no-rate"
              class="input-no-rate"
              name="review[rating]"
              value="1"
              checked
              aria-label="No rating."
            />

            <input
              type="radio"
              id="first-rate1"
              name="review[rating]"
              value="1"
            />
            <label for="first-rate1" title="Terrible">
              1 star
            </label>

            <input
              type="radio"
              id="first-rate2"
              name="review[rating]"
              value="2"
            />
            <label for="first-rate2" title="Not good">
              2 stars
            </label>

            <input
              type="radio"
              id="first-rate3"
              name="review[rating]"
              value="3"
            />
            <label for="first-rate3" title="Average">
              3 stars
            </label>

            <input
              type="radio"
              id="first-rate4"
              name="review[rating]"
              value="4"
            />
            <label for="first-rate4" title="Very good">
              4 stars
            </label>

            <input
              type="radio"
              id="first-rate5"
              name="review[rating]"
              value="5"
            />
            <label for="first-rate5" title="Amazing">
              5 stars
            </label>
          </fieldset>
        </div>

        <!-- Comment -->
        <div class="mb-3 mt-3">
          <label for="comment" class="form-label">Comment:</label>
          <textarea
            id="comment"
            name="review[comment]"
            cols="38"
            rows="10"
            class="form-control"
            required
          ></textarea>
          <div class="valid-feedback">
            Comment Looks good!
          </div>
          <div class="invalid-feedback">
            Please enter a comment for the review.
          </div>
        </textarea>
        </div>

        <button type="submit" class="btn btn-outline-dark">
          Submit Review
        </button>
      </form>

      <hr />
    <% } %>

    <!-- Display Reviews -->
    <p><b>Reviews:</b></p>

    <div class="row">
      <% for(review of listing.reviews) { %>
        <div class="card col-5 ms-3 mb-3 review-card">
          <div class="card-body">
            <!-- Reviewer Name -->
            <h5 class="card-title">
              @<%= review.author.username %>
            </h5>

            <!-- Rating -->
            <p
              class="starability-result card-text"
              data-rating="<%= review.rating %>"
            >
              Rated: <%= review.rating %> stars
            </p>

            <!-- Review Comment -->
            <p class="card-text">
              <b>Comment:</b> <%= review.comment %>
            </p>
          </div>

          <!-- Delete Review Button (only show if review author) -->
          <% if(currentUser && currentUser._id.toString() === review.author._id.toString()) { %>
            <form
              class="mb-3"
              action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
              method="POST"
            >
              <button type="submit" class="btn btn-sm btn-dark">
                Delete Review
              </button>
            </form>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>
