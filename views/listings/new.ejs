<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <h3>Create New Listing</h3>
    <form action="/listings" method="POST">
        <input type="text" name="listing[title]" placeholder="Enter Title" required><br><br>
        <textarea name="listing[description]" placeholder="Enter Description" required></textarea><br> <br>
        <input type="text" name="listing[image]" placeholder="Enter Image URL" required><br><br>
        <input type="number" name="listing[price]" placeholder="Enter Price" required><br><br>
        <input name = "listing[country]" placeholder="Enter Country" required><br><br>
        <input name = "listing[location]" placeholder="Enter Location" required><br><br>
        <button type="submit">Create Listing</button>
    </form>
    
</body>
</html>